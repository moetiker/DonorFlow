{
  "name": "donorflow",
  "version": "0.6.7",
  "description": "Modern donation management system for clubs and organizations",
  "keywords": [
    "donation-management",
    "fundraising",
    "nonprofit",
    "clubs",
    "associations",
    "nextjs",
    "typescript",
    "prisma",
    "sqlite",
    "react",
    "nextauth",
    "i18n",
    "self-hosted"
  ],
  "author": "Manuel Oetiker <manuel@oetiker.ch>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moetiker/DonorFlow.git"
  },
  "homepage": "https://github.com/moetiker/DonorFlow",
  "scripts": {
    "dev": "next dev -p 7526",
    "build": "next build",
    "start": "next start -p 7526",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed-real.ts",
    "db:migrate-orphans": "tsx prisma/migrate-orphans-to-club-pool.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed-real.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed-real.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.8",
    "next": "^16.2.10",
    "next-auth": "^4.24.13",
    "next-intl": "^4.13.2",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-typeahead": "^6.4.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prisma": "^7.2.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
