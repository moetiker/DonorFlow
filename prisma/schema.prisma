// Prisma Schema für Spendenverwaltung

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Spendenart
enum DonationType {
  MONETARY  // Geldspende
  IN_KIND   // Sachspende
}

// Vereinsmitglieder
model Member {
  id              String            @id @default(cuid())
  firstName       String
  lastName        String
  email           String?           // E-Mail-Adresse
  phone           String?           // Mobiltelefon
  groupId         String?           // Direkte Zuordnung zu einer Gruppe (optional)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  statusToken     String?           @unique  // For members without group - public status link

  // Beziehungen
  group           Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  sponsors        Sponsor[]
  memberTargets   MemberTarget[]
  donations       Donation[]        // Spenden, die direkt diesem Mitglied zugeordnet sind

  @@index([groupId])
}

// Gruppen von Vereinsmitgliedern
model Group {
  id              String            @id @default(cuid())
  name            String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  statusToken     String?           @unique  // Public status link for group

  // Beziehungen
  members         Member[]
  sponsors        Sponsor[]
  donations       Donation[]  // Spenden, die direkt dieser Gruppe zugeordnet sind
}

// Vorgabe pro Mitglied pro Vereinsjahr
model MemberTarget {
  id              String     @id @default(cuid())
  memberId        String
  fiscalYearId    String
  targetAmount    Float      // CHF
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  member          Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fiscalYear      FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@unique([memberId, fiscalYearId])
  @@index([fiscalYearId])
}

// Gönner
model Sponsor {
  id              String     @id @default(cuid())

  // Kontaktdaten
  company         String?    // Firma
  salutation      String?    // Anrede (Herr, Frau, Fam.)
  firstName       String?    // Vorname
  lastName        String?    // Name (wird nach Migration Pflichtfeld)
  street          String?    // Strasse
  postalCode      String?    // PLZ
  city            String?    // Ort
  phone           String?    // Telefon
  email           String?    // E-Mail

  notes           String?    // Kommentare / zusätzliche Infos

  // Zuordnung: Entweder zu Mitglied ODER zu Gruppe
  memberId        String?
  groupId         String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  member          Member?    @relation(fields: [memberId], references: [id], onDelete: SetNull)
  group           Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  donations       Donation[]

  @@index([memberId])
  @@index([groupId])
}

// Spenden von Gönnern
model Donation {
  id              String       @id @default(cuid())
  sponsorId       String
  type            DonationType @default(MONETARY)  // Spendenart (Geld oder Sach)
  amount          Float?       // CHF (nur für Geldspenden)
  description     String?      // Beschreibung (nur für Sachspenden)
  donationDate    DateTime
  fiscalYearId    String?      // Zuordnung zu Vereinsjahr
  note            String?

  // Zuordnung: Entweder zu Mitglied ODER zu Gruppe (XOR constraint)
  // Wird beim Erstellen automatisch vom Sponsor übernommen, kann aber überschrieben werden
  memberId        String?      // Zuordnung zu Mitglied
  groupId         String?      // Zuordnung zu Gruppe

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sponsor         Sponsor      @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  fiscalYear      FiscalYear?  @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  member          Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  group           Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([sponsorId])
  @@index([donationDate])
  @@index([fiscalYearId])
  @@index([memberId])
  @@index([groupId])
  @@index([type])
}

// Vereinsjahre (Geschäftsjahre)
model FiscalYear {
  id              String         @id @default(cuid())
  name            String         @unique // z.B. "2024/2025"
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  memberTargets   MemberTarget[]
  donations       Donation[]
  donorLetter     DonorLetter?

  @@index([startDate])
}

// Gönnerbrief pro Vereinsjahr (als PDF in der DB gespeichert)
model DonorLetter {
  id              String     @id @default(cuid())
  fiscalYearId    String     @unique
  fileName        String
  mimeType        String
  size            Int
  data            Bytes
  uploadedAt      DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  fiscalYear      FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
}

// Benutzer für Login
model User {
  id              String    @id @default(cuid())
  username        String    @unique
  passwordHash    String
  name            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Einstellungen (Key-Value Store)
model Setting {
  id              String    @id @default(cuid())
  key             String    @unique
  value           String
  description     String?
  updatedAt       DateTime  @updatedAt
}
